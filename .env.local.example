# Salin fail ini ke .env.local dan isi nilai sebenar.
# .env.local TIDAK di-commit (diabaikan oleh .gitignore).

# ── Borang public (sedia ada) ───────────────────────────────────────────
# URL Web App Google Apps Script (berakhir dengan /exec).
# Lihat google-apps-script.gs + README.md §4 untuk cara dapatkan.
SHEETS_WEBHOOK_URL=

# ── Portal Ahli: Clerk (auth) ───────────────────────────────────────────
# Dari Clerk Dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Laluan portal (jangan ubah — sudah sepadan dengan struktur folder).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/portal/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/portal/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portal/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/portal/onboarding

# ── Portal Ahli: Supabase (database) ────────────────────────────────────
# Dari Supabase Dashboard → Project Settings → Data API / API Keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
